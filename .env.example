# Copy this file to .env and fill in real values. Never commit .env.

# ── GCP ───────────────────────────────────────────────────────────────────────
# Bucket name is derived by Terraform as <project-id>-openaq-raw (infra/variables.tf)
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcp-project-id-openaq-raw
BIGQUERY_DATASET=openaq_dbt
BIGQUERY_RAW_DATASET=openaq_raw
# Must equal the datasets' region (BQ jobs run in exactly one location)
BIGQUERY_LOCATION=us-central1
# Host path of the SA key, used two ways: CLI runs read it via
# GOOGLE_APPLICATION_CREDENTIALS; docker-compose bind-mounts GCP_KEY_FILE into
# the Airflow containers (which use the container path, set in compose).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GCP_KEY_FILE=/path/to/service-account-key.json

# ── OpenAQ API ────────────────────────────────────────────────────────────────
OPENAQ_API_KEY=your-openaq-api-key
OPENAQ_API_BASE_URL=https://api.openaq.org/v3

# ── Airflow ───────────────────────────────────────────────────────────────────
# Set to your host uid (`id -u`) so container-written files (logs/) aren't
# owned by a foreign uid on the host.
AIRFLOW_UID=50000
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow

# ── dbt ───────────────────────────────────────────────────────────────────────
DBT_PROJECT_DIR=/opt/airflow/dbt
DBT_PROFILES_DIR=/opt/airflow/dbt

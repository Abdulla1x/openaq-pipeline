# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
ENV/

# Environments — commit only the example template, never the real file
.env
.env.*
!.env.example

# ── Airflow ───────────────────────────────────────────────────────────────────
airflow/logs/
airflow.db
standalone_admin_password.txt

# ── dbt ───────────────────────────────────────────────────────────────────────
dbt/target/
dbt/dbt_packages/
dbt/logs/
dbt/.user.yml

# ── GCP credentials ───────────────────────────────────────────────────────────
*-key.json
*-credentials.json
service-account*.json
credentials.json
gcp_keyfile.json

# ── Terraform ─────────────────────────────────────────────────────────────────
# .terraform.lock.hcl is deliberately NOT ignored: committing it pins provider
# versions so every machine and CI run resolves identical providers.
.terraform/
*.tfstate
*.tfstate.backup
*.tfplan
*.tfvars
!*.tfvars.example

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ── Local working notes — private session context, never committed ───────────
CLAUDE.local.md
.claude/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
._*
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# Phase 5 backfill checkpoint file (local run state, never shared)
backfill_state.json

# Phase 5 observability artifacts (local-only)
.venv-edr/
elementary_report.html
edr_target/
